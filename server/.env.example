# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/vivek_jhabak_associates

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# CORS Configuration
CORS_ORIGIN=*

# Nodemailer SMTP settings (e.g. Gmail App Password or custom SMTP server)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_email_here@gmail.com
SMTP_PASS=your_smtp_app_password_here
SMTP_FROM=no-reply@vivekjhabak.com

# Admin Notification Configuration
ADMIN_NOTIFY_EMAIL=vivekjhabak@gmail.com

# Supabase Storage Integration Configurations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key_here
SUPABASE_STORAGE_BUCKET=resumes
