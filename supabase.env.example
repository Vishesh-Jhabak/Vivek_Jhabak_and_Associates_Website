# =========================================================================
# SUPABASE CONFIGURATION TEMPLATE - VIVEK JHABAK & ASSOCIATES
# =========================================================================

# 1. FRONTEND ENVIRONMENT VARIABLES (Vite Client Prefixed)
# These are exposed to your React client code via `import.meta.env`
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_anon_public_key

# 2. BACKEND API ENVIRONMENT VARIABLES (Node.js/Express SDK)
# Used if you route requests through your Express server
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...your_secret_service_role_key

# 3. DIRECT POSTGRESQL DATABASE CONNECTIONS
# If you are querying the Supabase PostgreSQL database directly via Prisma, pg, or Sequelize
# Connection String (Transactional pooling - Port 6543)
DATABASE_URL=postgres://postgres.your-project-ref:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct Connection String (Migration/Direct - Port 5432)
DIRECT_URL=postgres://postgres.your-project-ref:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# 4. SUPABASE STORAGE BUCKET CONFIGURATION
# Name of the Supabase storage bucket where resume PDFs will be stored
SUPABASE_STORAGE_BUCKET=resumes

# 5. OTHER SETTINGS
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
